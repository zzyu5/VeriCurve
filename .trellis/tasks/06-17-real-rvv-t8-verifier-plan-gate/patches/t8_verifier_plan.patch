+static std::vector<block_q8_0> slice_rhs(
+        const std::vector<block_q8_0> & rhs,
+        int nb,
+        int token_offset,
+        int T) {
+    std::vector<block_q8_0> out((size_t) T * nb);
+    const auto begin = rhs.begin() + (size_t) token_offset * nb;
+    const auto end = rhs.begin() + (size_t) (token_offset + T) * nb;
+    std::copy(begin, end, out.begin());
+    return out;
+}
