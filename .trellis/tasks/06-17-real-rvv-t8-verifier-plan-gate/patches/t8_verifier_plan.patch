+        const std::vector<block_q8_0> & packed_rhs_second4,
+        int nb,
+        volatile float & sink) {
+    const int row_groups = rows / R;
+    double total_ns = 0.0;
+
+    for (int iter = 0; iter < warmup + repeats; ++iter) {
+        const double t0 = seconds_now();
