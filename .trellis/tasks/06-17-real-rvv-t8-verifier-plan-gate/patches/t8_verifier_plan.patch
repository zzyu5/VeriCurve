+            accumulate_group(rg, R, 4, use_packed_rhs, use_rowblocked_weights,
+                             weights, packed_weights,
+                             rhs_first4, packed_rhs_first4, nb, acc_first);
+            accumulate_group(rg, R, 4, use_packed_rhs, use_rowblocked_weights,
+                             weights, packed_weights,
+                             rhs_second4, packed_rhs_second4, nb, acc_second);
+
+            float local = 0.0f;
+            for (int rr = 0; rr < R; ++rr) {
+                for (int tt = 0; tt < 4; ++tt) {
+                    local += acc_first[rr][tt] + acc_second[rr][tt];
+                }
+            }
+            sink += local * 0.0000001f;
+        }
+        const double t1 = seconds_now();
+        if (iter >= warmup) {
+            total_ns += (t1 - t0) * 1.0e9;
+        }
+    }
+    return total_ns / repeats;
+}
