+static uint64_t vc_mix_u64(uint64_t h, uint64_t v) {
+    return h ^ (v + 0x9e3779b97f4a7c15ULL + (h << 6) + (h >> 2));
+}
+
+static uint64_t vc_hash_i64(int64_t v) {
+    return static_cast<uint64_t>(v) ^ 0x9e3779b97f4a7c15ULL;
+}
+
+static uint64_t vc_hash_tokens(const std::vector<llama_token> & tokens, size_t suffix_len) {
+    const size_t start = suffix_len > 0 && tokens.size() > suffix_len ? tokens.size() - suffix_len : 0;
+    uint64_t h = 1469598103934665603ULL;
+    h = vc_mix_u64(h, tokens.size());
+    for (size_t i = start; i < tokens.size(); ++i) {
+        h = vc_mix_u64(h, vc_hash_i64(tokens[i]));
+    }
+    return h;
+}
+
+struct vc_cache_stats {
+    uint64_t hash;
+    size_t ngrams;
+    size_t edges;
+    int64_t count_sum;
+};
+
+static vc_cache_stats vc_hash_ngram_cache(const common_ngram_cache & cache) {
+    std::vector<std::array<int64_t, LLAMA_NGRAM_MAX + 2>> entries;
+    entries.reserve(cache.size());
+    int64_t count_sum = 0;
+    for (const auto & item : cache) {
+        const common_ngram & ngram = item.first;
+        for (const auto & token_count : item.second) {
+            std::array<int64_t, LLAMA_NGRAM_MAX + 2> entry{};
+            for (int i = 0; i < LLAMA_NGRAM_MAX; ++i) {
+                entry[i] = ngram.tokens[i];
+            }
+            entry[LLAMA_NGRAM_MAX] = token_count.first;
+            entry[LLAMA_NGRAM_MAX + 1] = token_count.second;
+            count_sum += token_count.second;
+            entries.push_back(entry);
+        }
+    }
+    std::sort(entries.begin(), entries.end());
+    uint64_t h = 1469598103934665603ULL;
+    h = vc_mix_u64(h, cache.size());
+    h = vc_mix_u64(h, entries.size());
+    h = vc_mix_u64(h, vc_hash_i64(count_sum));
+    for (const auto & entry : entries) {
+        for (int64_t v : entry) {
+            h = vc_mix_u64(h, vc_hash_i64(v));
+        }
+    }
+    return { h, cache.size(), entries.size(), count_sum };
+}
+
+static int vc_count_accept(
+        const std::vector<llama_token> & target,
+        int position,
+        const std::vector<llama_token> & draft) {
+    int accepted = 0;
+    for (size_t j = 1; j < draft.size() && position + accepted < (int) target.size(); ++j) {
+        if (target[position + accepted] != draft[j]) {
+            break;
+        }
+        ++accepted;
+    }
+    return accepted;
+}
+
+static void vc_candidate_signature(
+        std::vector<llama_token> & pseudo,
+        const std::vector<llama_token> & target,
