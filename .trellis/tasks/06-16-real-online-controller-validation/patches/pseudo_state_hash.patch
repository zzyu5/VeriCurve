+        common_ngram_cache & nc_context,
+        common_ngram_cache & nc_dynamic,
+        common_ngram_cache & nc_static,
+        int & drafted,
+        int & accepted,
+        uint64_t & draft_hash) {
+    std::vector<llama_token> draft;
+    draft.push_back(pseudo.back());
+    if (candidate_d > 0) {
+        common_ngram_cache_draft(pseudo, draft, candidate_d, LLAMA_NGRAM_MIN, LLAMA_NGRAM_MAX, nc_context, nc_dynamic, nc_static);
+    }
+    drafted = draft.size() > 0 ? draft.size() - 1 : 0;
+    accepted = vc_count_accept(target, pseudo.size(), draft);
+    draft_hash = vc_hash_tokens(draft, 0);
+}
 
